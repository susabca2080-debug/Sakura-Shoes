 <!-- # FOR addproductsize.php
 #to fetch sizes not already assigned to a product -->
 <?php
include 'databaseconn.php';

$product_id = intval($_GET['product_id']); // safe

$sql = "SELECT * FROM sizes 
        WHERE size_id NOT IN 
        (SELECT size_id FROM product_sizes WHERE product_id = $product_id)";

$result = $conn->query($sql);

$options = "<option value=''>-- Select Size --</option>";

while ($row = $result->fetch_assoc()) {
    $options .= "<option value='" . $row['size_id'] . "'>"
        . htmlspecialchars($row['size_name']) . "</option>";
}

echo $options;
?>
    
<!-- #we have to add this script before the end of form tag in dashbord.php -->
<script>
    // 1️⃣ Select the product dropdown by its ID and listen for changes
document.getElementById('product_id').addEventListener('change', function () {

    // 2️⃣ Get the value of the selected product
    // 'this' refers to the product dropdown
    // 'this.value' will be the product_id chosen by the user
    let productId = this.value;

    // 3️⃣ If no product is selected (user selects the first empty option)
    if (productId === "") {
        // 3a. Reset the size dropdown to show a default message
        document.getElementById("size_id").innerHTML =
            "<option value=''>-- Select a product first --</option>";
        // 3b. Stop executing the rest of the function
        return;
    }

    // 4️⃣ If a product is selected, fetch available sizes from the server
    // fetch() makes an HTTP request to 'fetch_sizes.php'
    // We pass the selected product ID as a GET parameter
    fetch("fetch_sizes.php?product_id=" + productId)
        // 4a. Convert the server response into text (the HTML <option> elements)
        .then(response => response.text())
        // 4b. 'data' now contains the HTML <option> tags returned by PHP
        .then(data => {
            // 4c. Replace the inner HTML of the size dropdown with the fetched options
            // This updates the dropdown with only the sizes not already assigned to the selected product
            document.getElementById("size_id").innerHTML = data;
        });
});
    </script>
<!-- end -->


